---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

// 1. Import your JSON data directly from your project files
import ingredientsData from "../data/ingredients.json";
import NutritionFactsLabel from "../assets/NutritionFactsLabel.astro";
---

<Layout title="Lunch Shake Calculator">
  <main class="flex flex-col justify-center min-h-screen">
    <div class="bg-emerald-600">
      <h1 class="text-3xl font-bold text-center text-amber-500 mb-8 h-2">
        LunchShake Calculator
      </h1>
    </div>
    <div class="w-full flex flex-row justify-center">
      <div
        class="flex md:flex-row flex-col gap-4 justify-center rounded-2xl drop-shadow-2 bg-gray-200 p-3 min-w-fit max-w-3"
      >
        <div class="pad-3 margin-2 min-w-fit">
          <div class="bg-indigo-50 p-4 rounded-lg">
            <h2 class="text-lg font-semibold text-indigo-900 mb-2">
              Total Serving Size
            </h2>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Target Weight: <span
                id="total-weight-display"
                class="font-bold text-indigo-600">100</span
              >g
            </label>
            <input
              type="range"
              id="total-weight-slider"
              min="10"
              max="1000"
              step="10"
              value="100"
              class="w-full h-2 bg-indigo-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>

          <div
            class="space-y-4 md:max-h-125 md:inset-shadow-sm/40 md:p-2 rounded-xl overflow-y-auto pr-2"
          >
            <h2 class="text-lg font-semibold text-gray-700 border-b pb-2">
              Recipe Selector
            </h2>

            {
              ingredientsData.map((item) => (
                <div class="border-b border-gray-100 pb-3">
                  <div class="flex justify-between text-sm font-medium text-gray-700 capitalize">
                    <span>{item.ingredient}</span>
                    <span>
                      <span
                        data-actual={item.ingredient}
                        class="font-bold text-indigo-600"
                      >
                        0
                      </span>
                      g
                    </span>
                  </div>
                  <input
                    type="range"
                    min="0"
                    max="100"
                    value="25"
                    data-ingredient={item.ingredient}
                    class="w-full accent-emerald-600 ingredient-slider"
                  />
                </div>
              ))
            }
          </div>
        </div>

        <NutritionFactsLabel />
      </div>
    </div>

    <footer class="sticky flex flex-row justify-center">
      <div class="bg-gray-100 w-fit px-3 h-5 rounded-full ring-2 ring-blue-400">
        made by Benjamin
      </div>
    </footer>
  </main>

  <script is:inline define:vars={{ ingredientsData }}>
    window.ingredientsData = ingredientsData;
  </script>

  <script src="../assets/scripts/calculator.js"></script>
</Layout>
