---
import Layout from "../../layouts/Layout.astro";

// 1. Import your JSON data directly from your project files
import ingredientsData from "../../data/ingredients.json";

import "../../assets/scripts/calculator.js";
---

<Layout title="Lunch Shake Calculator">
  <main
    class="max-w-5xl mx-auto bg-white rounded-xl shadow-md p-6 md:p-8 my-10 font-sans"
  >
    <h1 class="text-3xl font-bold text-center text-indigo-700 mb-8">
      🥤 Custom Lunch Shake Builder
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="space-y-6">
        <div class="bg-indigo-50 p-4 rounded-lg">
          <h2 class="text-lg font-semibold text-indigo-900 mb-2">
            1. Total Serving Size
          </h2>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Target Weight: <span
              id="total-weight-display"
              class="font-bold text-indigo-600">400</span
            >g
          </label>
          <input
            type="range"
            id="total-weight-slider"
            min="100"
            max="1000"
            step="10"
            value="400"
            class="w-full h-2 bg-indigo-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
          />
        </div>

        <div class="space-y-4 max-h-[500px] overflow-y-auto pr-2">
          <h2 class="text-lg font-semibold text-gray-700 border-b pb-2">
            2. Recipe Ratios
          </h2>

          {
            ingredientsData.map((item) => (
              <div class="border-b border-gray-100 pb-3">
                <div class="flex justify-between text-sm font-medium text-gray-700 capitalize">
                  <span>{item.ingredient}</span>
                  <span>
                    <span
                      data-actual={item.ingredient}
                      class="font-bold text-indigo-600"
                    >
                      0
                    </span>
                    g
                  </span>
                </div>
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="25"
                  data-ingredient={item.ingredient}
                  class="w-full accent-emerald-600 ingredient-slider"
                />
              </div>
            ))
          }
        </div>
      </div>

      <div class="flex justify-center items-start">
        <div
          class="border-2 border-black p-4 w-full max-w-sm bg-white text-black font-sans"
        >
          <h2
            class="text-4xl font-black border-b-8 border-black pb-1 leading-none tracking-tight"
          >
            Nutrition Facts
          </h2>

          <table class="w-full text-sm">
            <thead>
              <tr class="border-b-4 border-black text-left font-bold">
                <th class="py-1">Serving size</th>
                <th class="py-1 text-right"
                  ><span id="label-serving-size">400</span>g</th
                >
              </tr>
              <tr class="border-b-8 border-black text-xl font-black">
                <th class="py-1">Calories</th>
                <th
                  class="py-1 text-right text-4xl font-black"
                  id="label-calories">0</th
                >
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-300 font-bold">
                <td class="py-1">Total Fat</td>
                <td class="py-1 text-right"><span id="label-fat">0</span>g</td>
              </tr>
              <tr class="border-b border-gray-300 font-bold">
                <td class="py-1">Total Carbohydrate</td>
                <td class="py-1 text-right"><span id="label-carbs">0</span>g</td
                >
              </tr>
              <tr class="border-b border-gray-200 text-gray-600 text-xs italic">
                <td class="py-1 pl-4">Dietary Fiber</td>
                <td class="py-1 text-right"><span id="label-fiber">0</span>g</td
                >
              </tr>
              <tr class="border-b border-gray-200 text-gray-600 text-xs italic">
                <td class="py-1 pl-4">Total Sugars</td>
                <td class="py-1 text-right"
                  ><span id="label-sugars">0</span>g</td
                >
              </tr>
              <tr class="border-b-4 border-black font-bold">
                <td class="py-1">Protein</td>
                <td class="py-1 text-right"
                  ><span id="label-protein">0</span>g</td
                >
              </tr>
            </tbody>
          </table>

          <div class="text-[10px] text-gray-500 pt-2 leading-tight">
            Nutritional information calculated dynamically based on ingredient
            ratios. Values are calculated per gram based on formulation logs.
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
